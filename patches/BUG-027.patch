def create_protocol_request(..., data: bytes, force_flood: bool = False):
    timestamp = PacketBuilder._get_timestamp()
    plaintext = timestamp.to_bytes(4, "little") + bytes(data)
    payload, _, _ = PacketBuilder._create_encrypted_payload(contact, local_identity, plaintext)
    route_type = "flood" if force_flood or contact.out_path_len == OUT_PATH_UNKNOWN else "direct"
    packet = PacketBuilder._create_packet(PacketBuilder._create_header(PAYLOAD_TYPE_REQ, route_type), payload)
    return packet, timestamp
