async def forward_routed_ack(self, packet, rx_meta):
    if self.seen_cache.contains(packet.dedupe_key):
        return False
    self.seen_cache.add(packet.dedupe_key)
    packet.pop_next_hop()
    return await self.transmit(packet, delay=self.direct_delay(packet, rx_meta))

async def forward_multipart(self, packet, rx_meta):
    self.multipart_tracker.observe(packet.message_id, packet.remaining_parts)
    return await self.forward_according_to_route(packet, rx_meta)
